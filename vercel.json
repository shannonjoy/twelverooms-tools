{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "functions": {
    "api/*.py": {
      "includeFiles": "api/_*/**"
    }
  },
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.thetwelverooms.com" }],
      "destination": "https://thetwelverooms.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/moon/:date", "destination": "/api/moon_day?date=:date" }
  ]
}
